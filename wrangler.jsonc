{
    "$schema": "./node_modules/wrangler/config-schema.json",
    "name": "minesweeper",
    "compatibility_date": "2026-01-01",
    "main": "./src/index.ts",
    "assets": {
        "directory": "./build",
        "binding": "ASSETS"
    },
    "kv_namespaces": [
